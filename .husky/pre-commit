# Set PATH to include node
export PATH="/opt/homebrew/opt/node@22/bin:$PATH"

# CRITICAL: Check for protected file violations
echo "🛡️  Checking critical files protection..."
node tools/change-management/critical-files-protection.js validate-commit || exit 1

# Run quick tests before commit
echo "🧪 Running pre-commit tests..."

# Run unit tests (quick mode)
npm run test:unit:quick

# Run linting
npm run lint

# Clear stale .next cache to prevent SIGABRT crashes during build
rm -rf apps/web/.next

# Check for TypeScript errors
npm run build --quiet || (echo "❌ Build failed. Please fix TypeScript errors." && exit 1)

echo "✅ Pre-commit checks passed!"
