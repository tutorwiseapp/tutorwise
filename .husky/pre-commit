# Set PATH to include node
export PATH="/opt/homebrew/opt/node@22/bin:$PATH"

# CRITICAL: Check for protected file violations
echo "🛡️  Checking critical files protection..."
node tools/change-management/critical-files-protection.js validate-commit || exit 1

# Run quick tests before commit
echo "🧪 Running pre-commit tests..."

# Run unit tests (quick mode)
npm run test:unit:quick

# Run linting
npm run lint

# Kill any running dev server to prevent cache contention during build
lsof -ti :3000 2>/dev/null | xargs kill -9 2>/dev/null || true
sleep 1

# Clear stale .next cache to prevent SIGABRT crashes during build
rm -rf apps/web/.next || true

# Increase heap size to prevent SIGABRT during large builds
export NODE_OPTIONS="--max-old-space-size=8192"

# Check for TypeScript errors (use tsc for reliability; next build can SIGABRT on large codebases)
npx tsc --noEmit --project apps/web/tsconfig.json || (echo "❌ TypeScript check failed." && exit 1)

echo "✅ Pre-commit checks passed!"
